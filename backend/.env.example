# Google Workspace (required for real ingest)
GOOGLE_CREDENTIALS_JSON=
GOOGLE_WORKSPACE_ADMIN_USER=admin@domain.tld
DOMAIN=yourdomain.tld

# Security
SUPPORT_EMAIL=support@domain.tld
ACTION_FLAG=false
SEVERITY_THRESHOLD=70
LOOKBACK_MINUTES=15

# Which backends to use when ACTION_FLAG=true (config only; no code changes)
ENABLE_GOOGLE_WORKSPACE=true
ENABLE_ACTIVE_DIRECTORY=false
# NOTE:
# - ACTION_FLAG=false -> containment is PROPOSED only (no account disable actions executed)
# - ACTION_FLAG=true  -> executes enabled containment backends below

# Active Directory (used only when ENABLE_ACTIVE_DIRECTORY=true)
AD_LDAP_URL=
AD_BIND_DN=
AD_BIND_PASSWORD=
AD_BASE_DN=

# Mass outbound email burst detection
MASS_SEND_ENABLED=true
MASS_SEND_RECIPIENT_THRESHOLD=50
MASS_SEND_WINDOW_MINUTES=10
MASS_SEND_MESSAGE_THRESHOLD=20
MASS_SEND_UNIQUE_RECIPIENT_THRESHOLD=80
MASS_SEND_INTERNAL_ONLY_IGNORE=true
MASS_SEND_ALLOWLIST_SENDERS=alerts@domain.tld,news@domain.tld
MASS_SEND_ALLOWLIST_SUBJECT_KEYWORDS=Newsletter,Reminder
MASS_SEND_SEVERITY_POINTS_SINGLE=70
MASS_SEND_SEVERITY_POINTS_BURST=60

# Database (override in docker-compose or prod)
DATABASE_URL=postgresql+psycopg2://workspace_agent:workspace_agent_secret@localhost:5432/workspace_security

# SMTP for email alerts
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true

# App
APP_ENV=dev
SECRET_KEY=change-me-in-prod-with-32plus-chars
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UI_BASE_URL=http://localhost:5173
